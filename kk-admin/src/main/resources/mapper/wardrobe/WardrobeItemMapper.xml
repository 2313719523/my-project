<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kk.wardrobe.mapper.WardrobeItemMapper">

    <resultMap type="WardrobeItem" id="WardrobeItemResult">
        <result property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="category" column="category"/>
        <result property="color" column="color"/>
        <result property="season" column="season"/>
        <result property="price" column="price"/>
        <result property="isCommon" column="is_common"/>
        <result property="addTime" column="add_time"/>
        <result property="remark" column="remark"/>
        <result property="style" column="style"/>
        <result property="isFavorite" column="is_favorite"/>
        <result property="imgUrl" column="img_url"/>
    </resultMap>

    <sql id="selectWardrobeItemVo">
        select id, name, category, color, season, price, is_common, add_time, remark,
               style, is_favorite, img_url, create_by, create_time
        from wardrobe_item
    </sql>

    <select id="selectWardrobeItemList" parameterType="WardrobeItem" resultMap="WardrobeItemResult">
        <include refid="selectWardrobeItemVo"/>
        <where>
            <if test="name != null and name != ''"> AND name like concat('%', #{name}, '%')</if>
            <if test="category != null and category != ''"> AND category = #{category}</if>
            <if test="style != null and style != ''"> AND style = #{style}</if>
        </where>
        order by add_time desc
    </select>

    <update id="updateWardrobeItem" parameterType="WardrobeItem">
        update wardrobe_item
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="category != null">category = #{category},</if>
            <if test="style != null">style = #{style},</if>
            <if test="isFavorite != null">is_favorite = #{isFavorite},</if>
            <if test="imgUrl != null">img_url = #{imgUrl},</if>
            update_time = sysdate()
        </trim>
        where id = #{id}
    </update>

</mapper>