<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kk.system.mapper.OutfitConfigMapper">

    <resultMap type="com.kk.system.domain.OutfitConfig" id="OutfitConfigResult">
        <result property="configId"    column="config_id"    />
        <result property="configType"  column="config_type"  />
        <result property="configName"  column="config_name"  />
        <result property="status"      column="status"       />
        <result property="createTime"  column="create_time"  />
    </resultMap>

    <sql id="selectOutfitConfigVo">
        select config_id, config_type, config_name, status, create_time from outfit_config
    </sql>

    <select id="selectOutfitConfigList" parameterType="com.kk.system.domain.OutfitConfig" resultMap="OutfitConfigResult">
        <include refid="selectOutfitConfigVo"/>
        <where>
            <if test="configType != null  and configType != ''"> and config_type = #{configType}</if>
            <if test="configName != null  and configName != ''"> and config_name like concat('%', #{configName}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>

    <insert id="insertOutfitConfig" parameterType="com.kk.system.domain.OutfitConfig" useGeneratedKeys="true" keyProperty="configId">
        insert into outfit_config(
        <if test="configType != null and configType != ''">config_type,</if>
        <if test="configName != null and configName != ''">config_name,</if>
        <if test="status != null and status != ''">status,</if>
        create_time
        )values(
        <if test="configType != null and configType != ''">#{configType},</if>
        <if test="configName != null and configName != ''">#{configName},</if>
        <if test="status != null and status != ''">#{status},</if>
        sysdate()
        )
    </insert>

    <delete id="deleteOutfitConfigById" parameterType="Long">
        delete from outfit_config where config_id = #{configId}
    </delete>

</mapper>